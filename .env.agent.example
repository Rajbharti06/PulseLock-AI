# Google ADK — required for Gemini model
GOOGLE_API_KEY=your_google_api_key_here

# PulseLock backend URL (where your FastAPI backend is running)
PULSELOCK_URL=http://localhost:8000

# PulseLock service account credentials (used by the ADK agent to authenticate)
PULSELOCK_USERNAME=admin
PULSELOCK_PASSWORD=admin123

# API key that Prompt Opinion will use to call this agent
API_KEYS=your_secure_api_key_here

# Public URL where this agent is deployed (for Agent Card registration)
PULSELOCK_AGENT_URL=https://your-agent.example.com

# Prompt Opinion workspace URL
PO_PLATFORM_BASE_URL=https://your-workspace.promptopinion.ai

# Port for the A2A server
AGENT_PORT=8001
